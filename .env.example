# Liferay Tunnel Client Environment Configuration
# Copy this file to .env and configure your variables before running lfr-tunnel

# Gateway Server URL (e.g., https://lfr-demo.se)
LFT_SERVER=https://lfr-demo.se

# Shared Authentication Token (must match gateway server configuration)
LFT_TOKEN=YOUR_SHARED_SECRET_TOKEN

# Subdomain prefix you want to register (e.g. test-se)
# If empty, your local computer's hostname will be used as a fallback
LFT_SUBDOMAIN=

# Comma-separated local ports to expose (e.g. 8080 or 8080,3000)
LFT_PORTS=8080
